{
  "name": "@jsonschema-editor/vue",
  "version": "0.1.0",
  "description": "JSON-Schema Form-Editor und ausfüllbares Formular für Vue 3",
  "type": "module",
  "main": "./dist/jsonschema-editor-vue.js",
  "module": "./dist/jsonschema-editor-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/jsonschema-editor-vue.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@jsonschema-editor/json-schema": "file:../jsonschema-editor-json-schema",
    "@jsonschema-editor/ui-schema": "file:../jsonschema-editor-ui-schema"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10"
  }
}
