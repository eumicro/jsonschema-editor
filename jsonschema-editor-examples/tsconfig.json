{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@jsonschema-editor/vue": ["../jsonschema-editor-vue/src/index.ts"],
      "@jsonschema-editor/vue/style.css": ["../jsonschema-editor-vue/src/style.css"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
