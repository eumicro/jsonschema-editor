{
  "oneOf": [
    {
      "$ref": "#/$defs/Mensch"
    },
    {
      "$ref": "#/$defs/Maschine"
    }
  ],
  "title": "Ansprechpartner",
  "description": "Erfassen Sie eine Person oder ein zugeordnetes Betriebsmittel mit Kontaktdaten",
  "$defs": {
    "Mensch": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "Name",
          "description": "Vollständiger Name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "description": "Geschäftliche E-Mail-Adresse"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "title": "Website",
          "description": "Website der Abteilung oder des Unternehmens"
        },
        "phone": {
          "type": "string",
          "format": "phone",
          "title": "Telefon",
          "description": "Telefonnummer mit Ländervorwahl"
        },
        "abteilung": {
          "type": "string",
          "title": "Abteilung",
          "description": "Zuständige Abteilung",
          "enum": ["Vertrieb", "Entwicklung", "Support"],
          "x-values-source": {
            "kind": "static",
            "values": ["Vertrieb", "Entwicklung", "Support"]
          }
        },
        "manager": {
          "type": "string",
          "title": "Vorgesetzter",
          "description": "Auswahl aus der Mitarbeiterliste",
          "x-values-source": {
            "kind": "fetch",
            "url": "https://jsonplaceholder.typicode.com/users",
            "valueField": "id",
            "labelField": "name"
          }
        }
      },
      "required": [
        "name"
      ],
      "title": "Person",
      "description": "Natürliche Person mit Kontaktdaten"
    },
    "Maschine": {
      "type": "object",
      "properties": {
        "nummer": {
          "type": "string",
          "title": "Nummer",
          "description": "Serien- oder Inventarnummer"
        }
      },
      "required": [
        "nummer"
      ],
      "title": "Betriebsmittel",
      "description": "Gerät oder Anlage mit Inventarnummer"
    }
  }
}
