{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mehrsprachiger Inhalt",
  "type": "object",
  "required": [
    "contentId",
    "defaultLocale",
    "localizations"
  ],
  "properties": {
    "contentId": {
      "type": "string"
    },
    "defaultLocale": {
      "type": "string",
      "enum": [
        "de",
        "en",
        "fr",
        "es"
      ]
    },
    "localizations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/LocalizationEntry"
      }
    }
  },
  "$defs": {
    "LocalizationEntry": {
      "type": "object",
      "required": [
        "locale",
        "title",
        "status"
      ],
      "properties": {
        "locale": {
          "type": "string",
          "enum": [
            "de",
            "en",
            "fr",
            "es"
          ]
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "published"
          ]
        },
        "translatorId": {
          "type": "string"
        }
      }
    }
  }
}