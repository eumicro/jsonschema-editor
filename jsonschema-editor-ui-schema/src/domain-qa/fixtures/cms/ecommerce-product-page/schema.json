{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Produktseite",
  "type": "object",
  "required": [
    "productId",
    "hero"
  ],
  "properties": {
    "productId": {
      "type": "string"
    },
    "hero": {
      "$ref": "#/$defs/ProductHero"
    },
    "specifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SpecRow"
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ProductReview"
      }
    },
    "crossSell": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ProductHero": {
      "type": "object",
      "required": [
        "title",
        "price",
        "gallery"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "price": {
          "$ref": "#/$defs/PriceInfo"
        },
        "gallery": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PriceInfo": {
      "type": "object",
      "required": [
        "amount",
        "currency"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "enum": [
            "EUR",
            "USD"
          ]
        },
        "discountPct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "SpecRow": {
      "type": "object",
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "ProductReview": {
      "type": "object",
      "required": [
        "rating",
        "author",
        "text"
      ],
      "properties": {
        "rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "author": {
          "type": "string"
        },
        "text": {
          "type": "string",
          "minLength": 10
        },
        "verifiedPurchase": {
          "type": "boolean"
        }
      }
    }
  }
}