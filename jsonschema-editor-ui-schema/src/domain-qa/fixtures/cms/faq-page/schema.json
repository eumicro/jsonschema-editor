{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FAQ-Seite",
  "type": "object",
  "required": [
    "pageTitle",
    "slug",
    "categories"
  ],
  "properties": {
    "pageTitle": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/FaqCategory"
      }
    }
  },
  "$defs": {
    "FaqCategory": {
      "type": "object",
      "required": [
        "name",
        "items"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/FaqItem"
          }
        }
      }
    },
    "FaqItem": {
      "type": "object",
      "required": [
        "question",
        "answer",
        "order"
      ],
      "properties": {
        "question": {
          "type": "string"
        },
        "answer": {
          "type": "string",
          "minLength": 10
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "featured": {
          "type": "boolean"
        }
      }
    }
  }
}