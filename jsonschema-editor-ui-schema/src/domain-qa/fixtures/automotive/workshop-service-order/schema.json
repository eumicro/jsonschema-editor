{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Serviceauftrag",
  "type": "object",
  "required": [
    "orderNumber",
    "customer",
    "vehicle",
    "jobs"
  ],
  "properties": {
    "orderNumber": {
      "type": "string"
    },
    "customer": {
      "$ref": "#/$defs/ServiceCustomer"
    },
    "vehicle": {
      "$ref": "#/$defs/ServiceVehicle"
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ServiceJob"
      }
    },
    "approval": {
      "$ref": "#/$defs/CustomerApproval"
    }
  },
  "$defs": {
    "ServiceCustomer": {
      "type": "object",
      "required": [
        "name",
        "phone"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "ServiceVehicle": {
      "type": "object",
      "required": [
        "vin",
        "mileageKm"
      ],
      "properties": {
        "vin": {
          "type": "string",
          "minLength": 17,
          "maxLength": 17
        },
        "mileageKm": {
          "type": "integer",
          "minimum": 0
        },
        "licensePlate": {
          "type": "string"
        }
      }
    },
    "ServiceJob": {
      "type": "object",
      "required": [
        "code",
        "description",
        "laborHours"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "laborHours": {
          "type": "number",
          "minimum": 0.1
        },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "partNumber",
              "quantity"
            ],
            "properties": {
              "partNumber": {
                "type": "string"
              },
              "quantity": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "CustomerApproval": {
      "type": "object",
      "required": [
        "approved",
        "maxCostEur"
      ],
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "maxCostEur": {
          "type": "number",
          "minimum": 0
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}