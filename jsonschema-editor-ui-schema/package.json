{
  "name": "@jsonschema-editor/ui-schema",
  "version": "0.1.2",
  "description": "Objektorientiertes JSON-UI-Schema-Datenmodell",
  "type": "module",
  "license": "MIT",
  "author": "JSON Schema Editor Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eumicro/jsonschema-editor.git",
    "directory": "jsonschema-editor-ui-schema"
  },
  "homepage": "https://github.com/eumicro/jsonschema-editor/tree/main/jsonschema-editor-ui-schema#readme",
  "bugs": "https://github.com/eumicro/jsonschema-editor/issues",
  "keywords": [
    "ui-schema",
    "jsonforms",
    "json-schema",
    "form",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "prebuild": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "domain-qa:fixtures": "tsx src/domain-qa/build-fixtures.ts"
  },
  "peerDependencies": {
    "@jsonschema-editor/json-schema": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@jsonschema-editor/json-schema": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jsonforms/core": "^3.7.0",
    "@jsonschema-editor/json-schema": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
